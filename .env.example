# Copy this file to `.env` in the project root and fill in your values.
# Never commit `.env` — it is gitignored.
#
#   cp .env.example .env
#
# Get keys: https://developers.kite.trade/ (create a Kite Connect app)

# ── Zerodha Kite Connect (required for live NSE quotes + future live orders) ──

# From Kite Connect developer console → your app → API Key
KITE_API_KEY=your_api_key_here

# From same page → API Secret (used once daily to exchange request_token)
KITE_API_SECRET=your_api_secret_here

# Generated daily via: vhe kite-login-url → login → vhe kite-exchange-token
# Expires around 6 AM IST next day — refresh every morning before market open
KITE_ACCESS_TOKEN=your_access_token_here

# ── VHE platform toggles ──

# Config file:
#   live_free.yaml   — FREE: simulated prices + paper orders (recommended without paid Connect)
#   live_paper.yaml  — same as live_free (simulated, no Kite creds required)
#   live_kite.yaml   — PAID Connect: live NSE quotes + paper orders
#   live_live.yaml   — PAID Connect: live quotes + real orders
VHE_LIVE_CONFIG=live_free.yaml

# Set to kite in configs/strategies.yaml → feed.source when using live quotes
# VHE does not read feed.source from here; edit configs/strategies.yaml instead
